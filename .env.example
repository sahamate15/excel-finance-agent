# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ─── Mistral (LLM) ───────────────────────────────────────────────────
# Get a free-tier key at https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=replace-me
MISTRAL_MODEL=mistral-small-latest
# Optional override (defaults to https://api.mistral.ai/v1):
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ─── Excel defaults ──────────────────────────────────────────────────
DEFAULT_EXCEL_FILE=data/sample_workbook.xlsx
DEFAULT_SHEET=Revenue

# ─── Behaviour ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RETRIES=2
# If true, hardcoded fallback formulas are tried before the LLM
FALLBACK_FIRST=true
# If true, the LLM is never contacted. Only the hardcoded formula map and
# heuristic table parser are used. Use this for compliance scenarios where
# no instruction-derived data may leave the machine. Instructions the
# offline path cannot resolve fail loudly with a clear error.
STRICT_MODE=false
